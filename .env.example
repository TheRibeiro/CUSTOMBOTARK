# ============================================================
#  ARKHERON SA — Custom Game Bot v2.0
#  Copie este arquivo para .env e preencha os valores
# ============================================================

# ─── OBRIGATORIOS ───
DISCORD_TOKEN=seu_token_aqui
GUILD_ID=id_do_servidor
SALAS_CHANNEL_ID=id_do_canal_salas
CUSTOM_CATEGORY_ID=id_da_categoria
LOG_CHANNEL_ID=id_do_canal_de_log
MIN_ROLE_ID=id_do_cargo_jogador

# ─── OPCIONAL ───
ADMIN_SALAS_CHANNEL_ID=id_do_canal_admin

# ─── MODO DEBUG (teste solo) ───
# Ative para testar sozinho no servidor
DEBUG_MODE=false
DEBUG_MIN_VOTES=1
DEBUG_SKIP_ROLE_CHECK=false

# ─── CONFIGURACOES AVANCADAS ───
# Timeout da votacao em ms (padrao: 180000 = 3 min)
VOTE_TIMEOUT_MS=180000

# Maximo de salas simultaneas (padrao: 20)
MAX_SALAS=20

# Tempo maximo de vida de uma sala em horas (padrao: 6)
MAX_ROOM_AGE_H=6

# Nivel de log: error, warn, info, debug (padrao: info)
LOG_LEVEL=info
